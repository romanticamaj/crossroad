# Crossroad — environment variables.
#
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`
# or any real secret. NEXT_PUBLIC_* values are exposed to the browser by design;
# everything else is server-only.
#
# For local development, `supabase start` prints the Supabase values, and the
# Stripe values come from your Stripe test-mode dashboard / the Stripe CLI.
# See the "Local setup" section of the README for step-by-step instructions.

# --- Supabase ---
# Project API URL (e.g. https://<ref>.supabase.co, or the local http://127.0.0.1:55321).
NEXT_PUBLIC_SUPABASE_URL=
# Publishable / anon key (safe in the browser; RLS governs access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role / secret key (SERVER ONLY — bypasses RLS; never expose to the client).
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (test mode) ---
# Secret key from the Stripe dashboard, test mode (starts with sk_test_).
STRIPE_SECRET_KEY=
# Webhook signing secret (starts with whsec_). From `stripe listen` locally, or
# the webhook endpoint config in the Stripe dashboard for deployed environments.
STRIPE_WEBHOOK_SECRET=
# Price id of the placeholder subscription plan (starts with price_).
STRIPE_PRICE_ID=

# --- App ---
# Public origin, used to build Stripe redirect URLs. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
